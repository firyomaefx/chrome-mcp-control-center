{
  "name": "chrome-mcp-control-center-desktop",
  "version": "1.0.1",
  "private": true,
  "description": "Chrome MCP Control Center — single-click Windows dashboard",
  "author": "Chrome MCP contributors",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis portable --x64",
    "dist:dir": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.chromemcp.controlcenter",
    "productName": "Chrome MCP Control Center",
    "forceCodeSigning": false,
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "runtime-bundle.mjs"
    ],
    "extraResources": [
      {
        "from": "runtime-bundle.mjs",
        "to": "runtime-bundle.mjs"
      },
      {
        "from": "../extension",
        "to": "extension"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ChromeMCPControlCenter-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Chrome MCP Control Center",
      "artifactName": "ChromeMCPControlCenter-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "ChromeMCPControlCenter-${version}-portable.exe"
    }
  }
}

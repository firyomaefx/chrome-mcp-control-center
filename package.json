{
  "name": "chrome-mcp-control-center",
  "version": "1.0.3",
  "private": true,
  "description": "Single-click Windows Chrome Computer-Use MCP — Control Center, MCP server, extension, and supervisor.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "chrome-mcp": "dist/cli.js",
    "chrome-mcp-host": "dist/native-host/host.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "postbuild": "node scripts/obsidian-export.mjs",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "serve": "node dist/cli.js serve",
    "serve:http": "node dist/cli.js serve-http",
    "test": "node --test --import tsx tests/permissions.test.ts tests/redact.test.ts tests/supervisor.test.ts tests/vertical-slice.test.ts tests/autofill.test.ts tests/computer-use.test.ts tests/extension-http-bridge.test.ts tests/connect-chrome.test.ts tests/extension-id.test.ts tests/cloud-sync.test.ts tests/auto-heal.test.ts",
    "test:e2e-bridge": "node --import tsx tests/extension-http-bridge.test.ts",
    "cloud:backend": "node cloud-backend/server.mjs",
    "typecheck": "tsc --noEmit",
    "bundle:runtime": "esbuild dist/cli.js --bundle --platform=node --format=esm --target=node20 --outfile=desktop/runtime-bundle.mjs --external:electron",
    "desktop": "npm run build && npm run bundle:runtime && npm --prefix desktop start",
    "desktop:pack": "npm run build && npm run bundle:runtime && npm --prefix desktop run dist && node scripts/obsidian-export.mjs",
    "obsidian:export": "node scripts/obsidian-export.mjs",
    "smoke:portability": "node scripts/smoke-portability.mjs",
    "version:sync": "node scripts/sync-version.mjs",
    "version:patch": "npm version patch --no-git-tag-version && node scripts/sync-version.mjs",
    "version:minor": "npm version minor --no-git-tag-version && node scripts/sync-version.mjs",
    "version:major": "npm version major --no-git-tag-version && node scripts/sync-version.mjs",
    "health": "node dist/cli.js health",
    "repair": "node dist/cli.js repair",
    "pretest": "node scripts/smoke-portability.mjs"
  },
  "keywords": [
    "mcp",
    "chrome",
    "browser-automation",
    "computer-use",
    "windows",
    "native-messaging"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "crx": "^5.0.1",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "esbuild": "^0.25.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}

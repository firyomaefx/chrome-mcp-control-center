{
  "manifest_version": 3,
  "name": "Chrome MCP Control Center",
  "version": "1.0.3",
  "description": "Connects Chrome to the local Chrome MCP Control Center for safe browser automation.",
  "permissions": [
    "nativeMessaging",
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Chrome MCP",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
